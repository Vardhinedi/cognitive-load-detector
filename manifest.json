{
  "manifest_version": 3,
  "name": "Cognitive Load Detector",
  "version": "1.0",
  "description": "Detects cognitive load from user interaction patterns",

  "permissions": ["storage", "activeTab", "scripting"],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "index.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}